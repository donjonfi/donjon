{
  "name": "donjon",
  "version": "3.7.0",
  "description": "Donjon FI",
  "author": {
    "name": "Jonathan Claes",
    "url": "https://github.com/donjonfi/donjon"
  },
  "scripts": {
    "ng": "ng",
    "start": "ng serve donjon-creer --configuration development",
    "start:compagnon": "ng serve donjon-compagnon --configuration development",
    "build": "ng build",
    "build:compagnon": "ng build donjon-compagnon --configuration bundle && node ../../scripts/sync-compagnon.js",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "test:prod": "ng test donjon --browsers=ChromeHeadlessCI --watch=false --code-coverage"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^21.2.9",
    "@angular/common": "^21.2.9",
    "@angular/compiler": "^21.2.9",
    "@angular/core": "^21.2.9",
    "@angular/forms": "^21.2.9",
    "@angular/platform-browser": "^21.2.9",
    "@angular/platform-browser-dynamic": "^21.2.9",
    "@angular/router": "^21.2.9",
    "@fortawesome/fontawesome-free": "^6.7.2",
    "bootstrap": "^5.3.8",
    "file-saver-es": "^2.0.5",
    "ngx-ace-wrapper": "^17.0.0",
    "ngx-bootstrap": "^21.0.1",
    "rand-seed": "^1.0.1",
    "rxjs": "~7.8.1",
    "tslib": "^2.4.0",
    "uuid": "^14.0.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^21.2.7",
    "@angular/cli": "^21.2.7",
    "@angular/compiler-cli": "^21.2.9",
    "@types/file-saver": "^2.0.5",
    "@types/jasmine": "^5.1.4",
    "@types/node": "^22.0.0",
    "@types/uuid": "^8.3.4",
    "jasmine-core": "^5.1.2",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.1.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "^2.1.0",
    "ng-packagr": "^21.2.3",
    "typescript": "~5.9.3"
  }
}
