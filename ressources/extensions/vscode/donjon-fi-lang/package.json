{
  "name": "donjon-fi-language",
  "displayName": "Donjon FI Language",
  "author": {
    "name": "Jonathan Claes",
    "url": "https://donjon.fi"
  },
  "publisher": "donjon-fi",
  "license": "MIT",
  "homepage": "https://donjon.fi",
  "description": "Syntax highlighting and snippets for Donjon FI lang",
  "version": "3.10.1",
  "icon": "donjon128.png",
  "preview": false,
  "engines": {
    "vscode": "^1.71.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/donjonfi/donjon"
  },
  "main": "./out/extension.js",
  "activationEvents": [
    "onLanguage:donjon"
  ],
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test": "tsc -p ./ && node --test out/declarationScanner.test.js out/formatter.test.js"
  },
  "devDependencies": {
    "@types/node": "^18.0.0",
    "@types/vscode": "^1.71.0",
    "typescript": "^5.4.0"
  },
  "contributes": {
    "languages": [
      {
        "id": "donjon",
        "aliases": [
          "Donjon",
          "donjon",
          "Donjon FI",
          "donjon.fi"
        ],
        "extensions": [
          ".djn"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "donjon",
        "scopeName": "source.djn",
        "path": "./syntaxes/donjon.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "donjon",
        "path": "./snippets/donjon.json"
      }
    ],
    "semanticTokenScopes": [
      {
        "language": "donjon",
        "scopes": {
          "variable": ["entity.name.variable.donjon"],
          "type": ["entity.name.type.donjon"]
        }
      }
    ],
    "configurationDefaults": {
      "editor.semanticTokenColorCustomizations": {
        "enabled": true,
        "rules": {
          "variable:donjon": {
            "fontStyle": "bold"
          },
          "type:donjon": {
            "fontStyle": "bold"
          }
        }
      }
    }
  }
}